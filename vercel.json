{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/index.html", "destination": "/", "statusCode": 301 },
    { "source": "/index.php", "destination": "/", "statusCode": 301 },
    { "source": "/index.htm", "destination": "/", "statusCode": 301 }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
