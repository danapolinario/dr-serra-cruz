# URL canónica do site (sem barra final). Usada em meta, OG, JSON-LD e geração do sitemap.
# Produção (domínio definitivo):
VITE_SITE_URL=https://www.drserracruz.com.br
#
# Pré-visualização Vercel (evita canonical/og apontando para outro domínio no deploy de preview):
# VITE_SITE_URL=https://dr-raphael-serra-cruz.vercel.app
#
# Definir no painel Vercel: Settings → Environment Variables → Production vs Preview.
