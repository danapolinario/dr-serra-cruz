{
  "name": "dr.-raphael-serra-cruz---especialista-em-joelho",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sitemap": "node scripts/gerar-sitemap.mjs && node scripts/gerar-url-manifest.mjs",
    "url-manifest": "node scripts/gerar-url-manifest.mjs",
    "validate:routes": "node scripts/validate-blog-routes.mjs",
    "build": "npm run sitemap && npm run validate:routes && vite build && node scripts/prerender.mjs",
    "build:no-prerender": "npm run sitemap && npm run validate:routes && vite build",
    "preview": "vite preview",
    "imagens:baixar": "node scripts/otimizar-imagens.mjs",
    "imagens:aplicar-caminhos": "node scripts/aplicar-caminhos-imagens.mjs",
    "imagens:seguidores-instagram": "node scripts/processar-seguidores-instagram.mjs",
    "imagens:logos-instituicoes": "node scripts/processar-logos-instituicoes.mjs",
    "imagens:cards-tratamentos": "node scripts/gerar-cards-tratamentos-webp.mjs"
  },
  "dependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@sparticuz/chromium": "^131.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "puppeteer-core": "^24.40.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
